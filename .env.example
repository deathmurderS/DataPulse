# DataPulse Configuration
# Copy this file to .env and fill in your values

# Database
POSTGRES_USER=datapulse
POSTGRES_PASSWORD=changeme
POSTGRES_DB=datapulse
POSTGRES_HOST=db
POSTGRES_PORT=5432

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RATE_LIMIT=10
API_RATE_LIMIT_WINDOW=60

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8501

# Scraper
SCRAPER_INTERVAL_HOURS=24
SCRAPER_TIMEOUT=30
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Notifications
NOTIFICATION_ENABLED=false
NOTIFICATION_TYPE=telegram  # telegram or email
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# Backup
BACKUP_DIR=/app/data/backup
BACKUP_RETENTION_DAYS=7

# Logging
LOG_LEVEL=INFO