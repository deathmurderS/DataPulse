# DataPulse .gitignore

# Environment files
.env
.env.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/
*.egg-info/

# Virtual environment
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Docker
docker-compose.override.yml

# Data & backups
data/backup/*
!data/backup/.gitkeep
data/sample/*
!data/sample/.gitkeep

# Logs
*.log
logs/

# Database
*.db
*.sqlite
*.sqlite3

# OS
.DS_Store
Thumbs.db

# Jupyter Notebook
.ipynb_checkpoints/

# Coverage
.coverage
htmlcov/
.coverage.*

# Frontend
frontend/node_modules/
frontend/dist/
